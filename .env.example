# ============================================================
# .env.example — salin file ini ke .env lalu isi nilainya
#   cp .env.example .env
# File .env TIDAK boleh di-commit ke Git (sudah ada di .gitignore)
# ============================================================

# ── Path project di dalam container ─────────────────────────
RETAIL_DBT_PROJECT_DIR=/project
RETAIL_DBT_PROFILES_DIR=/project
RETAIL_SNAPSHOT_BATCHES=3

# ── Exchange rate (override tiap bulan tanpa ubah kode) ──────
# Di-pass ke dbt via --vars di DAG
USD_TO_IDR_RATE=15800
SGD_TO_IDR_RATE=11900

# ── PostgreSQL (Airflow metadata DB) ─────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=airflow

# ── Airflow admin user ────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_strong_password_here
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_UID=50000

# ── Slack webhook (opsional) ──────────────────────────────────
# Isi untuk mengaktifkan alert Slack saat task Airflow gagal.
# Cara buat: https://api.slack.com/messaging/webhooks
# Kosongkan jika tidak pakai Slack.
SLACK_WEBHOOK_URL=
